PORT=5000
# MongoDB connection string - supports both MONGO_URI and MONGODB_URI
# For local MongoDB: mongodb://localhost:27017/ai-recon-db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/reconciliation_db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/ai-recon-db
# Alternative variable name (Render.com uses MONGODB_URI by convention)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/reconciliation_db
JWT_SECRET=your_jwt_signing_secret_here
NODE_ENV=development

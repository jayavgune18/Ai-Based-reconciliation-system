# ── Server Configuration ──
PORT=5000
NODE_ENV=development

# ── MongoDB Connection ──
# For local MongoDB: mongodb://localhost:27017/ai-recon-db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/reconciliation_db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/ai-recon-db
# Alternative variable name (Render.com uses MONGODB_URI by convention)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/reconciliation_db

# ── JWT Configuration ──
JWT_SECRET=your_jwt_signing_secret_here
JWT_EXPIRE=1d
JWT_COOKIE_EXPIRE=1

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Cookie Secret (for signed cookies) ──
COOKIE_SECRET=your_cookie_signing_secret_here

# ── OAuth - Google ──
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── OAuth - GitHub ──
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── OTP Config ──
OTP_EXPIRY_MINUTES=10